# Site Order — environment variables
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. NEVER commit real keys.
#
# Boundary rules (immutable — see CLAUDE.md):
#   * NEXT_PUBLIC_* variables are bundled into the browser. Only the
#     SUPABASE_URL and the ANON KEY may be public.
#   * SUPABASE_SERVICE_ROLE_KEY and OPENAI_API_KEY are SERVER-ONLY. Use
#     them only inside `app/api/**` route handlers or in one-off Node
#     scripts (e.g. `scripts/seed.ts`).

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — must never be referenced from a client component.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Optional — defaults to gpt-4o if unset.
OPENAI_MODEL=gpt-4o
